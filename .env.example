#!/bin/bash
# ======================================================
# pgBouncer 部署環境變數設定檔
# 複製此檔案為 .env 並修改成你的環境
# ======================================================

# ======================================================
# pgBouncer 版本設定
# ======================================================
PGBOUNCER_VERSION=1.22.1
PGBOUNCER_SOURCE_URL="https://www.pgbouncer.org/downloads/files/${PGBOUNCER_VERSION}/pgbouncer-${PGBOUNCER_VERSION}.tar.gz"

# ======================================================
# 安裝路徑設定
# ======================================================
PGBOUNCER_PREFIX="/usr/local/pgbouncer"
PGBOUNCER_CONFIG_DIR="/etc/pgbouncer"
PGBOUNCER_LOG_DIR="/var/log/pgbouncer"
PGBOUNCER_RUN_DIR="/var/run/pgbouncer"
PGBOUNCER_SOURCE_DIR="/usr/local/src"

# ======================================================
# 系統用戶設定
# ======================================================
PGBOUNCER_USER_UID=121
PGBOUNCER_GROUP_GID=127

# ======================================================
# PostgreSQL 連線資訊（用於建立 role 和 database）
# ======================================================
PG_HOST="localhost"
PG_PORT=5432
PG_SUPER_USER="postgres"

# pgBouncer 管理介面使用的 role（會在 PostgreSQL 中建立）
PGBOUNCER_ADMIN_ROLE="pgbouncer"
PGBOUNCER_ADMIN_PASSWORD="admin123"

# 應用程式資料庫設定（會自動建立）
APP_DB_NAME="app"
APP_DB_OWNER="doadmin"
APP_DB_OWNER_PASSWORD="admin123"

# 客戶端 role（給應用程式連線用）
CLIENT_ROLE="client"
CLIENT_PASSWORD="admin123"

# ======================================================
# pgBouncer 監聽設定
# ======================================================
PGBOUNCER_LISTEN_ADDR="*"
PGBOUNCER_PORT=6432

# ======================================================
# 連線池設定
# ======================================================
# 連線池模式：session、transaction、statement
# session: 連線在整個會話期間保持
# transaction: 連線在事務期間保持（推薦）
# statement: 連線在單一 SQL 語句後釋放
PGBOUNCER_POOL_MODE="transaction"

# 最大客戶端連線數：pgBouncer 能接受的最大客戶端連線數
# 建議：根據伺服器記憶體和 CPU 調整
# 計算方式：記憶體(MB) / 2 或 CPU 核心數 * 100
PGBOUNCER_MAX_CLIENT_CONN=1000

# 預設連線池大小：每個資料庫預設的連線池大小
# 建議：根據應用程式併發需求調整
# 一般設定：10-50 之間，避免過多連線造成資料庫壓力
PGBOUNCER_DEFAULT_POOL_SIZE=20

# 最小連線池大小：連線池保持的最小連線數
# 設定為 0 表示沒有最小限制，按需建立連線
# 設定為 >0 可以保持熱連線，減少連線建立時間
PGBOUNCER_MIN_POOL_SIZE=0

# 預備連線池大小：在高負載時額外建立的連線數
# 當連線池用盡時，會建立這些預備連線
# 建議：預設連線池大小的 1/4 到 1/2
PGBOUNCER_RESERVE_POOL_SIZE=5

# 預備連線超時時間（秒）：建立預備連線的最大等待時間
# 如果超時仍未建立連線，客戶端會收到錯誤
# 建議：3-10 秒，根據網路和資料庫響應時間調整
PGBOUNCER_RESERVE_POOL_TIMEOUT=5

# ======================================================
# SSL/TLS 設定
# ======================================================
# SSL 域名（用於憑證）
SSL_DOMAIN="test.supojen.com"

# PostgreSQL 資料目錄（用於尋找憑證檔案）
PGDATA="/var/lib/pgsql/data"

# SSL 憑證檔案路徑（從 Let's Encrypt 複製到 pgBouncer 目錄）
SSL_CERT_PATH="/etc/pgbouncer/ssl/server.crt"
SSL_KEY_PATH="/etc/pgbouncer/ssl/server.key"

# SSL 模式設定
# 前端 SSL（客戶端 -> pgBouncer）：require, prefer, disable, allow
CLIENT_TLS_SSLMODE="require"

# 後端 SSL（pgBouncer -> PostgreSQL）：require, prefer, disable, allow
SERVER_TLS_SSLMODE="disable"

# ======================================================
# 卸載選項
# ======================================================
KEEP_DATA=false
KEEP_CONFIG=false
SKIP_BACKUP=false